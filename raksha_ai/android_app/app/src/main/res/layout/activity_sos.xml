<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sos_red"
    android:padding="24dp">

    <TextView
        android:id="@+id/sosStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"
        android:gravity="center"
        android:text="ACTIVATE SOS"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/sosStatusText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Emergency services and contacts notified."
        android:textColor="@color/white"
        android:textSize="16sp" />

    <Button
        android:id="@+id/stopSOSButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:backgroundTint="@color/black"
        android:text="STOP ALARM &amp; SOS"
        android:textColor="@color/white" />

</RelativeLayout>
